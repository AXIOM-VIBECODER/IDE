  DB.seedDemo();const mem=Mem.startSession();const hasKey=!!getKey();
  console.clear();
  console.log('\n  ╔══════════════════════════════════════════════════════════════╗');
  console.log('  ║                    A X I O M  v5                            ║');
  console.log('  ║   Real Terminal · CodeMirror Editor · Full IDE Features      ║');
  console.log('  ║   Beats Cursor · Windsurf · Zed · Bolt · Copilot            ║');
  console.log('  ╚══════════════════════════════════════════════════════════════╝');
