server.on('upgrade',(req,socket,head)=>{
  const u=urlMod.parse(req.url,true);
  if(u.pathname.startsWith('/ws/')){
    socket.on('error',()=>{});
    handleWsUpgrade(req,socket,u.pathname);
  } else {
    socket.destroy();
  }
});

